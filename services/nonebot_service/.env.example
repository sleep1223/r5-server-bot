# NoneBot2 运行所使用的驱动器，文件默认一般只有这一行
# 见 https://nonebot.dev/docs/next/advanced/driver
DRIVER=~fastapi+~websockets+~httpx

# 重定向 localstore 插件的存储路径，便于后续迁移 Bot
LOCALSTORE_CACHE_DIR=data/nonebot/cache
LOCALSTORE_CONFIG_DIR=data/nonebot/config
LOCALSTORE_DATA_DIR=data/nonebot/data

# LogPile 日志文件保存路径
# LOGPILE_PATH=./log

# LogPile 日志输出等级，可以为列表
LOGPILE_LEVEL=INFO

# LogPile 日志保留天数
# LOGPILE_RETENTION=14

### NoneBot 配置项 ###

# 机器人超级用户
# 超级用户拥有对 Bot 的最高权限
SUPERUSERS=[""]

ACCESS_CONTROL_AUTO_PATCH_ENABLED=false

# NoneBot2 监听的 IP 或 主机名
# 如果要对公网开放，请改成 0.0.0.0
HOST=127.0.0.1
# NoneBot2 监听的端口
# 请保证该端口号与连接端配置相同 或与端口映射配置相关
PORT=8082

# NoneBot2 日志输出等级
LOG_LEVEL=INFO

### OneBot 适配器配置 ###

# OneBot Access Token 配置
ONEBOT_ACCESS_TOKEN=your_onebot_access_token

R5_API_BASE=http://127.0.0.1:8000/v1/r5
R5_API_TOKEN=your_r5_api_token
# Bot 调用 /admin 管理端接口用的 AppKey，需绑定到后端管理员玩家
R5_ADMIN_APP_KEY=your_admin_app_key

# 管理群成员会每日通过 OneBot get_group_member_list 刷新到 Bot 进程内缓存，并为已绑定玩家同步管理员权限
R5_ADMIN_GROUP_ID=1075088616
R5_ADMIN_GROUP_CACHE_SECONDS=86400
# 已通过 SUPERUSERS 或其它方式配置为管理员的 QQ，可在这里排除自动授权
R5_ADMIN_GROUP_GRANT_EXCLUDED_QQS=[]

# 新人入群欢迎，填写需要启用的 QQ 群号；空列表表示不启用
R5_GROUP_WELCOME_ENABLED_GROUPS=[]

# 加群自动审核（OpenAI 兼容 Chat Completions 接口）
R5_GROUP_JOIN_QUESTION=一句话证明你玩过apex
R5_GROUP_JOIN_LLM_API_KEY=your_llm_api_key
R5_GROUP_JOIN_LLM_BASE_URL=https://api.openai.com/v1
R5_GROUP_JOIN_LLM_MODEL=gpt-4o-mini
R5_GROUP_JOIN_LLM_TIMEOUT=10
# 大模型审核未通过时是否自动拒绝；false 时交由管理员处理
R5_GROUP_JOIN_LLM_REJECT_ON_FAIL=false
