# 日志等级 (TRACE/DEBUG/INFO/SUCCESS/WARNING/ERROR/CRITICAL)
log_level="INFO"

# Database settings
db_url="postgres://postgres:postgres@127.0.0.1:5432/r5"

# R5 Service settings
# remote servers url
# r5r.org or r5r-sl.ugniushosting.com or r5r-org.sleep0.de
r5_servers_url="https://r5r-org.sleep0.de/servers"
# 拉取远程服务器列表的时间间隔（秒），默认 180s = 3 分钟
r5_servers_fetch_interval=180

# KD/武器等战绩统计排除的服务器 IP（如无规则/纯娱乐服），命中则该服务器的击杀记录不计入统计；
# 通过 ?server=... 显式查询时仍可查看被排除服务器的单独数据
kd_excluded_server_hosts='["47.116.182.240"]'

# FastAPI Service settings
fastapi_host="0.0.0.0"
fastapi_port=8000
fastapi_cors_origins='["*"]'
fastapi_access_tokens='["your_api_token"]'

# Granian backlog / backpressure（ASGI workers 固定 1）
fastapi_backlog=1024
fastapi_backpressure=128

# 超级管理员平台用户 ID 列表（QQ 号）
super_admin_platform_uids='[]'

# Apex Legends Status API
apex_api_key="your_apex_api_key"
apex_api_url="https://api.apexlegendsstatus.com"
# 地图轮换 / 官方服务器状态 / 顶猎分数缓存刷新间隔（秒），默认 600s = 10 分钟
apex_cache_refresh_interval=600

# Match display settings
# /对局 过滤阈值：top1 击杀数 < 此值的对局不展示
recent_match_top_kills_threshold=50
# /竞技 每人每天取击杀前 N 场计入周榜
competitive_daily_match_limit=3
# /个人对局 默认最近 N 场
personal_match_default_limit=3

# 玩家每日击杀统计缓存刷新间隔（秒）
player_kill_daily_stats_refresh_interval_seconds=300
# 每轮刷新回看最近 N 天，覆盖迟到写入和短时间修正
player_kill_daily_stats_refresh_lookback_days=2

# Data settings
ip2region_path="services/fastapi_service/data/ip2region_v4.xdb"
launcher_config_path="services/fastapi_service/data/launcher_config.toml"
launcher_update_path="services/fastapi_service/data/launcher_update.toml"
# 启动器最新版本号优先来源：GitHub Releases。失败或未配置时回退到 launcher_update.toml 的 latest
launcher_github_repo="sleep1223/r5r-cn-launcher"
launcher_github_fetch_interval=600
