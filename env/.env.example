# Database settings
db_url="postgres://postgres:postgres@127.0.0.1:5432/r5"

# R5 Service settings
# remote servers url
# r5r.org or r5r-sl.ugniushosting.com or r5r-org.sleep0.de
r5_servers_url="https://r5r-org.sleep0.de/servers"
# 拉取远程服务器列表的时间间隔（秒），默认 180s = 3 分钟
r5_servers_fetch_interval=180

# console output netkey
r5_target_keys='["server_key"]'

# rcon_server.cfg
r5_rcon_key="rcon_key"
r5_rcon_password="sv_rcon_password"

# 无规则服务器(如北京服): 命中以下任一规则的服务器会跳过 NO_COVER 的 kick/ban 后台执行
# 按 IP 匹配
no_cover_allowed_server_hosts='["106.75.50.197"]'
# 按服务器名包含的子串匹配
no_cover_allowed_server_name_markers='["[CN(Beijing)]"]'

# WS Service settings
ws_host="127.0.0.1"
ws_port=7771
ws_batch_interval=60
ws_batch_max_retries=3


# FastAPI Service settings
fastapi_host="0.0.0.0"
fastapi_port=8000
fastapi_access_tokens='["your_api_token"]'

# Steam Auth / Pylon master-server settings
# Get a Steam Web API key at https://steamcommunity.com/dev/apikey
steam_web_api_key=""
# Steam App ID. 480 = Spacewar (test). Use the real game's app id in production.
steam_app_id="480"
# Optional: timeout (seconds) for Steam Web API calls
steam_auth_timeout=7.0
# Optional: also fetch Steam persona name via GetPlayerSummaries
steam_persona_lookup=true
# RSA keypair used to sign / verify JWTs handed to game clients.
# Generate with:
#   openssl genpkey -algorithm RSA -out services/fastapi_service/data/jwt_private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in services/fastapi_service/data/jwt_private.pem -pubout -out services/fastapi_service/data/jwt_public.pem
jwt_private_key_path="services/fastapi_service/data/jwt_private.pem"
jwt_public_key_path="services/fastapi_service/data/jwt_public.pem"
# Optional passphrase if the private key is encrypted
jwt_private_key_passphrase=""
# How long an issued JWT is valid for (seconds). Keep small — clients re-issue per connect.
jwt_token_ttl_seconds=30
# Default game server port appended when client only sends an IP without :port
pylon_default_server_port=37015

